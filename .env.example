# ─────────────────────────────────────────────────────────────────────────────
# SLUSH environment variables
#
# Copy to `.env.local` (gitignored) and fill in. NEVER commit real values.
# NEXT_PUBLIC_* is exposed to the browser — put ONLY non-secret values there.
# Everything else is server-only and must never carry a NEXT_PUBLIC_ prefix.
# Live Stripe keys are added only at deploy, by the owner, in Vercel — not here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public (safe in the browser) ────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Supabase "publishable" key (sb_publishable_…) — the modern replacement for the anon key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# ── Secret (server-only — never NEXT_PUBLIC_) ────────────────────────────────
# Supabase "secret" key (sb_secret_…) — modern replacement for service_role; bypasses RLS.
SUPABASE_SECRET_KEY=sb_secret_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 32-byte key, base64-encoded. Generate with:  openssl rand -base64 32
PII_ENCRYPTION_KEY=

TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Managed rate limiting (Upstash Redis, REST). Pick an EU region.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Error tracking (optional in local dev)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── CRM sync (CRM-agnostic; provider TBC) ────────────────────────────────────
# Leave CRM_PROVIDER blank to use the built-in log adapter (no external calls).
# Set to 'hubspot' / 'salesforce' / … once chosen, then add the key + base URL.
CRM_PROVIDER=
CRM_API_KEY=
CRM_BASE_URL=

# Shared secret for the CRM-drain cron route (Vercel Cron sends it as a Bearer).
CRON_SECRET=
